{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":dependencyDashboard",
    ":prHourlyLimitNone"
  ],
  "dependencyDashboard": true,
  "dependencyDashboardLabels": [
    "dependencies"
  ],
  "enabledManagers": [
    "github-actions",
    "npm",
    "pep621",
    "pyenv",
    "custom.regex"
  ],
  "schedule": [
    "before 6am on monday"
  ],
  "labels": [
    "dependencies"
  ],
  "lockFileMaintenance": {
    "enabled": true
  },
  "packageRules": [
    {
      "matchManagers": [
        "github-actions"
      ],
      "pinDigests": true
    },
    {
      "matchManagers": [
        "npm",
        "pep621",
        "pyenv"
      ],
      "rangeStrategy": "pin"
    },
    {
      "matchManagers": [
        "custom.regex"
      ],
      "groupName": "pre-commit hooks"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/(^|/)\\.pre-commit-config\\.yaml$/"
      ],
      "matchStrings": [
        "repo: https://github\\.com/(?<depName>[^\\s]+)\\s+rev: (?<currentDigest>[a-f0-9]{40}) # renovate: version=(?<currentValue>v?[^\\s]+)"
      ],
      "datasourceTemplate": "github-tags",
      "versioningTemplate": "semver-coerced",
      "autoReplaceStringTemplate": "repo: https://github.com/{{depName}}\n    rev: {{newDigest}} # renovate: version={{newValue}}"
    }
  ]
}
